# Vero Capital Holdings — API Keys Configuration
# Copy to api_keys.yaml and fill in your keys
# NEVER commit api_keys.yaml to version control

census:
  api_key: "your_census_api_key_here"
  base_url: "https://api.census.gov/data"

bls:
  api_key: "your_bls_api_key_here"
  base_url: "https://api.bls.gov/publicAPI/v2"

fred:
  api_key: "your_fred_api_key_here"
  base_url: "https://api.stlouisfed.org/fred"

zillow:
  # Zillow/Redfin data uses CSV downloads (no API key needed)
  zhvi_url: "https://files.zillowstatic.com/research/public_csvs/zhvi/Metro_zhvi_uc_sfrcondo_tier_0.33_0.67_sm_sa_month.csv"
  zori_url: "https://files.zillowstatic.com/research/public_csvs/zori/Metro_zori_uc_sfrcondomfr_sm_sa_month.csv"
